<odoo>

    <!-- TREE VIEW -->
    <record id="view_employee_tree" model="ir.ui.view">
        <field name="name">employee.tree</field>
        <field name="model">employee.crud</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="nik"/>
                <field name="position"/>
                <field name="phone"/>
                <field name="address"/>
            </tree>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_employee_form" model="ir.ui.view">
        <field name="name">employee.form</field>
        <field name="model">employee.crud</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="nik"/>
                        <field name="position"/>
                        <field name="phone"/>
                        <field name="address"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_employee" model="ir.actions.act_window">
        <field name="name">Employee</field>
        <field name="res_model">employee.crud</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- MENU -->
    <menuitem id="menu_employee_root" name="Employee"/>
    <menuitem id="menu_employee" name="Data Employee"
              parent="menu_employee_root"
              action="action_employee"/>
    
    <record id="view_employee_search" model="ir.ui.view">
        <field name="name">employee.search</field>
        <field name="model">employee.crud</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="nik"/>
                <field name="position"/>
            </search>
        </field>
    </record>

    <record id="action_employee" model="ir.actions.act_window">
        <field name="name">Employee</field>
        <field name="res_model">employee.crud</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_employee_search"/>
    </record>

</odoo>